{
  "Serilog": {
    "Using": [ "Serilog.Sinks.File", "Serilog.Formatting.Compact", "Serilog.Enrichers.Thread", "Serilog.Enrichers.Environment" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithThreadName",
      "WithMachineName"
    ],
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.json",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 90,
          "formatter": "Serilog.Formatting.Json.JsonFormatter, Serilog"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/errorlog-.json",
          "rollingInterval": "Day",
          "restrictedToMinimumLevel": "Error",
          "retainedFileCountLimit": 90,
          "formatter": "Serilog.Formatting.Json.JsonFormatter, Serilog"
        }
      }
    ]
  },
  "Otlp": {
    "LogsEndpoint": "http://localhost:14318/v1/logs",
    "TracesEndpoint": "http://localhost:14318/v1/traces",
    "MetricsEndpoint": "http://localhost:14318/v1/metrics"
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Redis": "redis-caching:6379"

  },
  "Jwt": {
    "Audience": "Ecommerce",
    "Issuer": "Ecommerce",
    "SecretKey": "185C2E54-C194-4FC9-8B0D-B2C25FB577D3"
  },
  "MessageBroker": {
    "Host": "amqp://rabbitmq-broker:15673",
    "Username": "guest",
    "Password": "guest"
  }
}
